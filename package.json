{
  "name": "yieldz-website",
  "author": "Yieldz",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NODE_ENV=production dotenv -e .env.$ENV -- next build",
    "start": "cross-env NODE_ENV=production dotenv -e .env.$ENV -- next start",
    "build:dev": "ENV=development npm run build",
    "build:qa": "ENV=qa npm run build",
    "build:uat": "ENV=uat npm run build",
    "build:pre-prod": "ENV=pre-prod npm run build",
    "build:prod": "ENV=production npm run build",
    "start:dev": "ENV=development npm run start",
    "start:qa": "ENV=qa npm run start",
    "start:uat": "ENV=uat npm run start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "format:write": "prettier --write \"**/*.{js,jsx,mjs,ts,tsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{js,jsx,mjs,ts,tsx,mdx}\" --cache",
    "test": "jest --watch"
  },
